int main()
{
	int a1=1,a2=2,a3=3,a4=4,a5=5,a6=6;
	int a7=7,a8=8,a9=9,a10=10,a11=11,a12=12;
	auto f=[=](auto &self,int n,int (*p)(int))->int
	{
		if(!n)
			return p(a1);
		else
			return self(self,n-1,[=](int x)->int{
				return p(x+a1+a2+a3+a4+a5+a6+a7+a8+a9+a10+a11+a12);
			});
	};
	return f(f,2,[](int x)->int{return x;});
}
