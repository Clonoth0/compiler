int main()
{
	auto f1=[](int x,int y)->int
	{
		auto g=[](int x,int y)->int
		{
			return x+y;
		};
		auto h=[](int x,int y)->int
		{
			return x*y;
		};
		return g(x,y)+h(x,y);
	};
	auto f2=[](int x,int y)->int
	{
		return [](int x,int y)->int
		{
			return x+y;
		}(x,y)+[](int x,int y)->int
		{
			return x*y;
		}(x,y);
	};
	return f1(1,2)+f2(2,3);
}
