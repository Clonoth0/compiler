int apply(int (*op)(int, int), int x, int y) { return op(x, y); }
int add(int x, int y) { return x + y; }
int mul(int x, int y) { return x * y; }
int sub(int x, int y) { return x - y; }
int main()
{
	int a=10;
	auto hof=[&](int (*f)(int,int),int (*g)(int,int),int (*h)(int,int),int x,int y)->int
	{
		int r1=f(x,y);
		int r2=g(r1,a);
		int r3=h(r2,r1);
		return r3;
	};
	return hof(add,mul,sub,3,4);
}
